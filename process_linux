#include <iostream>
#include <unistd.h>
#include <sys/wait.h>
#include <time.h>

using namespace std;

const int ITERATIONS = 50;

int main() {
    timespec start{}, end{};
    double totalTime = 0.0;

    for (int i = 0; i < ITERATIONS; i++) {
        clock_gettime(CLOCK_MONOTONIC, &start);

        pid_t pid = fork();

        if (pid == 0) {
            // Child exits immediately
            _exit(0);
        }
        else if (pid > 0) {
            wait(nullptr);

            clock_gettime(CLOCK_MONOTONIC, &end);

            double elapsed =
                (end.tv_sec - start.tv_sec) +
                (end.tv_nsec - start.tv_nsec) / 1e9;

            totalTime += elapsed;
        }
        else {
            cerr << "fork() failed" << endl;
            return 1;
        }
    }

    cout << "Average fork() time over "
         << ITERATIONS
         << " runs: "
         << (totalTime / ITERATIONS) * 1000
         << " ms" << endl;

    return 0;
}